---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Terms">
  <section class="section">
    <div class="section-inner article-body">
      <p class="eyebrow">Terms</p>
      <h1>Terms of use</h1>
      <p>
        My MetaTrader is a decentralized leverage trading platform. Content is provided for
        informational and educational purposes related to DeFi, leverage trading, and yield vaults.
      </p>
      <p>
        The platform does not provide financial advice. Trading with leverage involves significant
        risk, including the possibility of total loss. Past performance does not guarantee future
        results. Users are responsible for their own trading decisions and should conduct their own
        research before using leverage.
      </p>
      <p>
        External services such as wallet providers, blockchain networks, and oracle price feeds
        remain subject to their own terms and conditions.
      </p>
    </div>
  </section>
</Layout>
