---
import ArchiveNotice from "@/components/ArchiveNotice.astro";
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const sorted = [...posts].sort(
  (a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
);
const latest3 = sorted.slice(0, 3);
---

<Layout title="My MetaTrader / DeFi leverage trading DEX" description={site.description}>
  <ArchiveNotice />
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">My MetaTrader / Innovate Leverage Trading DEX</p>
      <h1>Trade smarter, not harder with up to 1000x leverage.</h1>
      <p class="lead">
        Take your crypto trading to the next level with leverage, a powerful tool that allows
        for larger trades and greater returns. Trade on the cutting edge of DeFi.
      </p>
      <div class="button-row">
        <a class="button" href="/gateway/">Trade now</a>
        <a class="button secondary" href="/blog/">Read field notes</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="My MetaTrader leverage summary">
      <div>
        <span>Max leverage</span>
        <strong>Up to 1000x</strong>
      </div>
      <div>
        <span>Execution</span>
        <strong>No scam wick</strong>
      </div>
      <div>
        <span>Yield</span>
        <strong>#RealYield vaults</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why using My MetaTrader</p>
        <h2>Trade on the cutting edge of DeFi.</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">How it works</p>
      <h2>Three steps to start trading.</h2>
      <div class="grid">
        <article class="card">
          <h3>Connect your wallet</h3>
          <p>Use a web3 browser or wallet app that supports Dapp interaction, such as MetaMask, and link it to access My MetaTrader.</p>
        </article>
        <article class="card">
          <h3>Pick a trading pair</h3>
          <p>Select your assets from a wide range of crypto and forex trading pairs, and trade with precision leveraging your positions.</p>
        </article>
        <article class="card">
          <h3>Make a trade</h3>
          <p>Insert capital, set stop-loss and take-profit levels, and select the appropriate leverage ratio to maximize profits while managing risk.</p>
        </article>
      </div>
    </div>
  </section>

  {latest3.length > 0 && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Latest trading notes</p>
        <h2>Fresh research from the DeFi trading frontier.</h2>
        <div class="latest-row">
          {latest3.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background:
      radial-gradient(circle at 20% 30%, rgba(34, 197, 94, 0.15) 0%, transparent 45%),
      radial-gradient(circle at 80% 70%, rgba(234, 179, 8, 0.12) 0%, transparent 45%),
      #0a0a0a;
    color: #f0fdf4;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero .lead {
    color: #86efac;
  }

  .hero-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 8px;
    background: rgba(20, 20, 20, 0.8);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
  }

  .hero-panel div {
    border-bottom: 1px solid rgba(34, 197, 94, 0.2);
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #86efac;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #f0fdf4;
    font-size: 20px;
    line-height: 1.2;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #22c55e;
    padding-left: 16px;
  }

  .hero .button {
    background: linear-gradient(135deg, #22c55e, #eab308);
    border: none;
    color: #0a0a0a;
  }

  .hero .button.secondary {
    background: transparent;
    border: 1px solid rgba(34, 197, 94, 0.45);
    color: #f0fdf4;
  }

  .latest-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-top: 36px;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      background-size: 720px;
      background-position: center bottom;
      padding-bottom: 300px;
    }

    .latest-row {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
