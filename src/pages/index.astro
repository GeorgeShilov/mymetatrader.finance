---
import Layout from '@/layouts/Layout.astro'; import LeadDialog from '@/components/LeadDialog.astro';
---
<Layout title="Trading intelligence cockpit"><div class="cockpit"><header><b>MYMETA<span>TRADER</span></b><div>GLOBAL SESSION <i>● LIVE</i></div><button data-lead>GET EARLY ACCESS</button></header><section class="dashboard"><div class="headline"><small>DECISION INTELLIGENCE / 09:41:22 UTC</small><h1>Trade the context,<br/>not the noise.</h1><p>A calm command layer for multi-market traders: thesis, risk and execution in one field of view.</p><button data-lead>BUILD MY COCKPIT →</button></div><figure><img src="/assets/generated/hero-cockpit.jpg" alt="Premium trading interface cockpit"/><figcaption><span>PORTFOLIO PULSE</span><b>+12.84%</b></figcaption></figure><aside><div><small>RISK MODE</small><b>Balanced</b></div><div><small>OPEN THESES</small><b>07</b></div><div><small>FOCUS</small><b>Macro / AI</b></div></aside></section><section class="modules"><article><span>01</span><h2>Thesis board</h2><p>Keep the reason beside every position.</p></article><article><span>02</span><h2>Risk radar</h2><p>See concentration before it becomes a problem.</p></article><article><span>03</span><h2>Execution journal</h2><p>Turn every trade into better judgment.</p></article></section><section class="operators"><img src="/assets/generated/trader-team.jpg" alt="Professional trading team"/><div><small>BUILT WITH ACTIVE OPERATORS</small><h2>Your edge deserves a quieter workspace.</h2><button data-lead>Talk to the product team</button></div></section><LeadDialog /></div></Layout>
<style>:global(.site-header),:global(.site-footer){display:none}.cockpit{background:#0c1017;color:#eef2f6;font-family:Arial,sans-serif;min-height:100vh}.cockpit>header{display:flex;justify-content:space-between;align-items:center;padding:18px 3vw;border-bottom:1px solid #303947}.cockpit>header span,.cockpit i{color:#54e7bb}.cockpit button{background:#54e7bb;border:0;border-radius:5px;padding:13px 18px;font-weight:900}.dashboard{display:grid;grid-template-columns:1.2fr 1.25fr 220px;gap:18px;padding:3vw;min-height:78vh}.headline{align-self:center}.headline h1{font-size:clamp(3.5rem,7vw,7rem);line-height:.9;letter-spacing:-.06em}.headline p{color:#9ca9b9;max-width:550px}.dashboard figure{margin:0;position:relative;border:1px solid #344250;border-radius:14px;overflow:hidden}.dashboard figure img{width:100%;height:100%;object-fit:cover}.dashboard figcaption{position:absolute;left:20px;right:20px;bottom:20px;padding:20px;background:#0c1017dd;display:flex;justify-content:space-between}.dashboard figcaption b{color:#54e7bb;font-size:2rem}.dashboard aside{display:grid;gap:12px}.dashboard aside div{border:1px solid #344250;border-radius:14px;padding:20px;display:flex;flex-direction:column;justify-content:space-between}.dashboard aside b{font-size:1.6rem}.modules{display:grid;grid-template-columns:repeat(3,1fr);border-block:1px solid #303947}.modules article{padding:4vw;border-right:1px solid #303947}.modules span{color:#54e7bb}.operators{display:grid;grid-template-columns:1.2fr 1fr;align-items:center;background:#161d27}.operators img{width:100%;height:620px;object-fit:cover}.operators div{padding:6vw}.operators h2{font-size:clamp(3rem,5vw,5rem);line-height:1}@media(max-width:900px){.dashboard{grid-template-columns:1fr}.dashboard figure{height:50vh}.dashboard aside{grid-template-columns:repeat(3,1fr)}.modules,.operators{grid-template-columns:1fr}.operators img{height:420px}}</style>
