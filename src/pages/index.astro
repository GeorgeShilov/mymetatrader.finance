---
import ArchiveNotice from "@/components/ArchiveNotice.astro";
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const featured = posts.find((post) => post.featured) || posts[0];
---

<Layout title="My MetaTrader / DeFi leverage trading DEX" description={site.description}>
  <ArchiveNotice />
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">My MetaTrader / Innovate Leverage Trading DEX</p>
      <h1>Trade smarter, not harder with up to 1000x leverage.</h1>
      <p class="lead">
        Take your crypto trading to the next level with leverage, a powerful tool that allows
        for larger trades and greater returns. Trade on the cutting edge of DeFi.
      </p>
      <div class="button-row">
        <a class="button" href="/gateway/">Trade now</a>
        <a class="button secondary" href="/blog/">Read field notes</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="My MetaTrader leverage summary">
      <div>
        <span>Max leverage</span>
        <strong>Up to 1000x</strong>
      </div>
      <div>
        <span>Execution</span>
        <strong>No scam wick</strong>
      </div>
      <div>
        <span>Yield</span>
        <strong>#RealYield vaults</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why using My MetaTrader</p>
        <h2>Trade on the cutting edge of DeFi.</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">How it works</p>
      <h2>Three steps to start trading.</h2>
      <div class="grid">
        <article class="card">
          <h3>Connect your wallet</h3>
          <p>Use a web3 browser or wallet app that supports Dapp interaction, such as MetaMask, and link it to access My MetaTrader.</p>
        </article>
        <article class="card">
          <h3>Pick a trading pair</h3>
          <p>Select your assets from a wide range of crypto and forex trading pairs, and trade with precision leveraging your positions.</p>
        </article>
        <article class="card">
          <h3>Make a trade</h3>
          <p>Insert capital, set stop-loss and take-profit levels, and select the appropriate leverage ratio to maximize profits while managing risk.</p>
        </article>
      </div>
    </div>
  </section>

  {featured && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Featured note</p>
        <h2>Start investing today.</h2>
        <PostCard post={featured} />
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background: linear-gradient(135deg, #020617 0%, #0f2e1f 50%, #022c22 100%);
    color: #fff;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero .lead {
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(17, 24, 39, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow);
  }

  .hero-panel div {
    border-bottom: 1px solid #d9dee8;
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #5c6676;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #101828;
    font-size: 20px;
    line-height: 1.2;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #06b6d4;
    padding-left: 16px;
  }

  .hero .button {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .hero .button.secondary {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.45);
    color: #fff;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      background-size: 720px;
      background-position: center bottom;
      padding-bottom: 300px;
    }
  }
</style>
