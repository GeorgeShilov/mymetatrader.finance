---
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
---

<Layout title="About">
  <section class="section">
    <div class="section-inner article-body">
      <p class="eyebrow">About</p>
      <h1>Built for traders who demand more.</h1>
      <p>
        {site.name} is a decentralized leverage trading exchange designed for traders who want
        maximum control and maximum opportunity. We combine deep liquidity, up to 1000x leverage,
        and no scam wick execution so you can trade with confidence.
      </p>
      <p>
        Unlike centralized exchanges, My MetaTrader is non-custodial. You connect your wallet and
        trade directly on-chain. No deposits, no withdrawal delays, and no counterparty risk from
        exchange insolvency.
      </p>
      <p>
        Our real yield vaults let stablecoin holders earn protocol revenue without inflationary
        token emissions. Yield comes from actual trading activity, not printed tokens.
      </p>
    </div>
  </section>
</Layout>
