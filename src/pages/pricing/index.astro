---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Fees">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Fees</p>
      <h1>Transparent fee structure.</h1>
      <p class="lead">
        No hidden costs. My MetaTrader charges straightforward trading fees and vault performance
        fees so you always know what you are paying for.
      </p>
      <div class="grid pricing">
        <article class="card"><h3>Maker</h3><p>Provide liquidity to the order book and earn a rebate on each filled order.</p><strong>0.02%</strong></article>
        <article class="card"><h3>Taker</h3><p>Take liquidity from the order book with immediate execution.</p><strong>0.07%</strong></article>
        <article class="card"><h3>Vault</h3><p>Performance fee on real yield generated from stablecoin deposit vaults.</p><strong>10%</strong></article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pricing {
    margin-top: 42px;
  }

  strong {
    display: block;
    margin-top: 28px;
    font-size: 30px;
  }
</style>
