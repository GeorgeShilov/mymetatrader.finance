---
import Layout from "@/layouts/Layout.astro";

const faqs = [
  ["What is My MetaTrader?", "A DeFi leverage trading DEX that offers up to 1000x leverage, no scam wick execution, and real yield vaults. You trade directly from your wallet without giving up custody."],
  ["How do I start trading?", "Connect a web3 wallet like MetaMask, select a trading pair, choose your leverage ratio, set stop-loss and take-profit levels, and confirm the trade."],
  ["What does no scam wick mean?", "Scam wicks are artificial price spikes that trigger liquidations. My MetaTrader uses protected price feeds and liquidation mechanics designed to filter out engineered volatility."],
  ["How do yield vaults work?", "Deposit stablecoins into vaults to earn real yield generated from protocol trading fees. There are no inflationary token emissions."],
  ["What are the risks of leverage trading?", "Leverage magnifies both gains and losses. Positions can be liquidated if the market moves against you. Always use stop-loss orders and only trade with capital you can afford to lose."]
];
---

<Layout title="FAQ">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">FAQ</p>
      <h1>Common questions before you trade.</h1>
      <div class="faq-list">
        {faqs.map(([question, answer]) => (
          <details class="card">
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .faq-list {
    display: grid;
    gap: 14px;
    margin-top: 40px;
  }

  summary {
    cursor: pointer;
    font-weight: 800;
    font-size: 20px;
  }

  details p {
    margin-top: 14px;
  }
</style>
