---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Trading Gateway">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Gateway</p>
      <h1>Your on-chain trading terminal.</h1>
      <p class="lead">
        Connect your wallet, pick a trading pair, and execute leveraged trades with up to 1000x
        magnification. No accounts. No custody. Just you, your wallet, and the market.
      </p>
      <div class="grid gateway-grid">
        <article class="card"><h3>1. Connect</h3><p>Link MetaMask or any web3 wallet to access the DEX directly. Your keys, your coins.</p></article>
        <article class="card"><h3>2. Select</h3><p>Choose from crypto and forex trading pairs with deep liquidity and tight spreads.</p></article>
        <article class="card"><h3>3. Configure</h3><p>Set leverage up to 1000x, define stop-loss and take-profit levels, and size your position.</p></article>
        <article class="card"><h3>4. Execute</h3><p>Submit your trade on-chain with transparent execution and no hidden manipulation.</p></article>
        <article class="card"><h3>5. Monitor</h3><p>Track open positions, margin health, and unrealized PnL in real time.</p></article>
        <article class="card"><h3>6. Earn</h3><p>Deposit stablecoins into real yield vaults and earn protocol revenue while you trade.</p></article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .gateway-grid {
    margin-top: 42px;
  }
</style>
